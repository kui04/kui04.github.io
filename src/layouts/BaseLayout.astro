---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import BaseHead from "@/components/BaseHead.astro";
import SnowBackground from "@/components/SnowBackground.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/constants";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION, bodyClass = "" } = Astro.props;
---

<!doctype html>
<html
  lang="zh"
  class="min-h-dvh w-full sm:max-w-[calc(100dvw-15px)] bg-bg text-text-base font-serif
         flex flex-col justify-center items-center overflow-hidden"
>
  <BaseHead title={title} description={description} />
  <ClientRouter />
  <body class={`flex-1 min-h-0 ${bodyClass}`.trim()}>
    <slot />
    <SnowBackground />
  </body>
</html>
