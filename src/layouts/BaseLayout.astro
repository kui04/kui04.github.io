---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SITE_TITLE, SITE_DESCRIPTION } from "@/constants";
import BaseHead from "@/components/BaseHead.astro";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION, bodyClass = "" } = Astro.props;
---

<!doctype html>
<html
  lang="zh"
  class="h-dvh scrollbar-thin w-[calc(100vw-10px)]
  bg-fixed bg-size-[1rem_1rem] bg-position-[-0.5rem_-0.5rem]
  bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)]
  bg-neutral-200 dark:bg-neutral-800
  scrollbar-track-neutral-200 dark:scrollbar-track-neutral-800
  scrollbar-thumb-neutral-400 dark:scrollbar-thumb-neutral-600"
>
  <BaseHead title={title} description={description} />
  <ClientRouter />
  <body class={bodyClass}>
    <slot />
    <script is:inline>
      (() => {
        const SCRIPT_ID = "snake-overlay-loader";

        function inject() {
          if (document.getElementById(SCRIPT_ID)) return;

          const s = document.createElement("script");
          s.id = SCRIPT_ID;
          s.src = "/scripts/snake.js";
          s.defer = true;
          document.body.appendChild(s);
        }

        function schedule() {
          if ("requestIdleCallback" in window) {
            requestIdleCallback(inject, { timeout: 2500 });
          } else {
            setTimeout(inject, 0);
          }
        }

        if (document.readyState === "complete") {
          schedule();
        } else {
          window.addEventListener("load", schedule, { once: true });
        }

        document.addEventListener("astro:page-load", schedule);
      })();
    </script>
  </body>
</html>
