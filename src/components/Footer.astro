---
import { AUTHOR_NAME } from "@/constants";

const year = new Date().getFullYear();
---

<footer class="flex items-center justify-between gap-2 py-4 px-4 sm:px-6 lg:px-8 text-xs text-text-secondary">
  <p>
    © {year}
    {AUTHOR_NAME} · Built with Astro
  </p>
  <div class="flex items-center gap-5 tracking-widest">
    <a
      href="https://github.com/kui04"
      target="_blank"
      rel="noopener noreferrer"
      class="transition-colors hover:text-accent"
    >
      GitHub
    </a>
    <a href="/rss.xml" class="transition-colors hover:text-text">RSS</a>
  </div>
</footer>
