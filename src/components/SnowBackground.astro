<canvas
  id="webgl-snow-fall"
  class="fixed top-0 left-0 -z-50 h-full w-full pointer-events-none"
  transition:persist="snow-background"></canvas>

<script>
  import REGL from "regl";

  (() => {
    "use strict";
    const canvas = document.getElementById("webgl-snow-fall") as HTMLCanvasElement;

    function resizeCanvas() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const rect = canvas.getBoundingClientRect();

      const width = Math.round(rect.width * dpr);
      const height = Math.round(rect.height * dpr);

      if (canvas.width !== width || canvas.height !== height) {
        canvas.width = width;
        canvas.height = height;
      }
    }

    window.addEventListener("resize", resizeCanvas);
    resizeCanvas();

    function buildProjection(fovDeg: number, aspect: number, near: number, far: number, camZ: number) {
      const fov = Math.tan(Math.PI * 0.5 - (0.5 * fovDeg * Math.PI) / 180);
      const rangeInv = 1.0 / (near - far);
      // prettier-ignore
      return new Float32Array([
        fov / aspect, 0  , 0                               , 0   ,
        0           , fov, 0                               , 0   ,
        0           , 0  , (near + far) * rangeInv         , -1  ,
        0           , 0  , near * far * rangeInv * 2 + camZ, camZ,
      ]);
    }

    function initParticles(count: number, halfW: number, halfH: number, halfD: number) {
      const pos = new Float32Array(count * 4);
      const col = new Float32Array(count * 4);
      const rot = new Float32Array(count * 3);
      const spd = new Float32Array(count * 3);
      const siz = new Float32Array(count);

      const minPx = 8;
      const maxPx = 24;

      for (let i = 0; i < count; i++) {
        const i4 = i * 4;
        const i3 = i * 3;

        pos[i4] = -halfW + Math.random() * halfW * 2;
        pos[i4 + 1] = -halfH + Math.random() * halfH * 2;
        pos[i4 + 2] = Math.random() * halfD * 2;
        pos[i4 + 3] = 1.0;

        spd[i3] = 1.0 + Math.random();
        spd[i3 + 1] = 1.0 + Math.random();
        spd[i3 + 2] = Math.random() * 10.0;

        rot[i3] = Math.random() * Math.PI * 2;
        rot[i3 + 1] = Math.random() * 10.0;
        rot[i3 + 2] = Math.random() * 5.0;

        col[i4] = 1.0;
        col[i4 + 1] = 1.0;
        col[i4 + 2] = 1.0;
        col[i4 + 3] = 0.15 + Math.random() * 0.3;

        siz[i] = (minPx + Math.random() * (maxPx - minPx)) * 64.0;
      }

      return {
        position: pos,
        color: col,
        rotation: rot,
        speed: spd,
        size: siz,
      };
    }

    const regl = REGL({ canvas });
    const config = { count: 1024, gravity: 100, fovDeg: 60, camZ: 128 };
    const aspect = window.innerWidth / window.innerHeight;
    const size = { halfH: 110, halfW: aspect * 110, halfD: 80 };

    const particleCount = Math.round(aspect * config.count);
    const particles = initParticles(particleCount, size.halfW, size.halfH, size.halfD);

    const snowTexture = regl.texture({ data: new Uint8Array([255, 255, 255, 0]), width: 1, height: 1 });
    const img = new Image();
    img.onload = () => snowTexture({ data: img, width: img.width, height: img.height });
    img.src = "/images/snow-flake.png";

    const windSim = (() => {
      let angle = 0.15;
      let angleGoal = 0.15;

      let speed = 1.0;
      let speedGoal = 1.0;

      let phase = "calm";
      let phaseT = 0;
      let coolDown = 3 + Math.random() * 5;
      // prettier-ignore
      let driftX = 0, driftY = 0, driftZ = 0;

      return {
        get drift() {
          return [driftX, driftY, driftZ];
        },

        update(dt: number) {
          angle += (angleGoal - angle) * dt * 0.06;
          if (Math.abs(angleGoal - angle) < 0.06) {
            angleGoal = (Math.random() - 0.5) * Math.PI * 1.4;
          }

          coolDown -= dt;
          phaseT -= dt;

          if (phase === "calm" && coolDown <= 0) {
            phase = "building";
            speedGoal = 4 + Math.random() * 11;
            phaseT = 0.6 + Math.random() * 1.2;
            coolDown = 6 + Math.random() * 14;
          } else if (phase === "building" && phaseT <= 0) {
            phase = "peak";
            phaseT = 1.0 + Math.random() * 2.0;
          } else if (phase === "peak" && phaseT <= 0) {
            phase = "fading";
            speedGoal = 0.5 + Math.random() * 1.2;
            phaseT = 2 + Math.random() * 3;
          } else if (phase === "fading" && phaseT <= 0) {
            phase = "calm";
          }

          const ease = phase === "building" ? 4.5 : 1.2;
          speed += (speedGoal - speed) * Math.min(dt * ease, 0.6);

          const s = 5.5;

          driftX += Math.sin(angle) * speed * dt * s;
          driftY += Math.cos(angle * 0.8) * speed * dt * s * 0.15;
          driftZ += Math.sin(angle * 0.6 + 0.4) * speed * dt * s * 0.12;
        },
      };
    })();

    const drawSnow = regl({
      vert: `
        precision highp float;

        attribute vec4 a_position;
        attribute vec4 a_color;
        attribute vec3 a_rotation;
        attribute vec3 a_speed;
        attribute float a_size;

        uniform float u_time;
        uniform vec2 u_resolution;
        uniform mat4 u_projection;
        uniform vec3 u_worldSize;
        uniform float u_gravity;
        uniform vec3  u_drift;

        varying vec4 v_color;
        varying float v_rotation;

        float hash(vec3 p) {
          p = fract(p * 0.3183099 + 0.1);
          p *= 17.0;
          return fract(p.x * p.y * p.z * (p.x + p.y + p.z));
        }

        float noise(vec3 p) {
          vec3 i = floor(p);
          vec3 f = fract(p);

          float a = hash(i);
          float b = hash(i + vec3(1.0, 0.0, 0.0));
          float c = hash(i + vec3(0.0, 1.0, 0.0));
          float d = hash(i + vec3(1.0, 1.0, 0.0));
          float e = hash(i + vec3(0.0, 0.0, 1.0));
          float f1 = hash(i + vec3(1.0, 0.0, 1.0));
          float g = hash(i + vec3(0.0, 1.0, 1.0));
          float h = hash(i + vec3(1.0, 1.0, 1.0));

          vec3 u = f * f * (3.0 - 2.0 * f);

          return mix(
            mix(mix(a, b, u.x), mix(c, d, u.x), u.y),
            mix(mix(e, f1, u.x), mix(g, h, u.x), u.y),
            u.z
          );
        }

        void main() {
          v_color    = a_color;
          v_rotation = a_rotation.x + u_time * a_rotation.y;

          vec3 pos = a_position.xyz;

          float w = a_speed.x;
          pos.x = mod(pos.x + u_drift.x * w, u_worldSize.x * 2.0) - u_worldSize.x;
          pos.y = mod(pos.y - u_time * a_speed.y * u_gravity + u_drift.y * w, u_worldSize.y * 2.0) - u_worldSize.y;
          pos.z = mod(pos.z + u_drift.z * w, u_worldSize.z * 2.0);

          float fx = noise(vec3(a_position.xy * 0.08 + u_time * 0.07, 0.3)) - 0.5;
          float fy = noise(vec3(a_position.yz * 0.08 + u_time * 0.05, 0.7)) - 0.5;
          pos.x += fx * a_rotation.z * 1.8;
          pos.y += fy * a_rotation.z * 0.7;

          pos.x += sin(u_time * a_speed.z) * a_rotation.z;
          pos.z += cos(u_time * a_speed.z) * a_rotation.z;

          gl_Position  = u_projection * vec4(pos, a_position.w);
          gl_PointSize = a_size / gl_Position.w;
        }
      `,
      frag: `
        precision highp float;

        uniform sampler2D u_texture;
        varying vec4 v_color;
        varying float v_rotation;

        void main() {
          vec2 coord = gl_PointCoord - 0.5;
          float c = cos(v_rotation);
          float s = sin(v_rotation);

          vec2 rotated = vec2(
            c * coord.x + s * coord.y + 0.5,
            c * coord.y - s * coord.x + 0.5
          );

          vec4 flake = texture2D(u_texture, rotated);
          gl_FragColor = vec4(flake.rgb, flake.a * v_color.a);
        }
      `,
      attributes: {
        a_position: regl.buffer(particles.position),
        a_color: regl.buffer(particles.color),
        a_rotation: regl.buffer(particles.rotation),
        a_speed: regl.buffer(particles.speed),
        a_size: regl.buffer(particles.size),
      },
      uniforms: {
        u_time: ({ time }) => time / 5.0,
        // prettier-ignore
        u_resolution: ({ drawingBufferWidth, drawingBufferHeight }) => [ drawingBufferWidth, drawingBufferHeight ],
        // prettier-ignore
        u_projection: ({ drawingBufferWidth, drawingBufferHeight }) => buildProjection(config.fovDeg, drawingBufferWidth / drawingBufferHeight, 1, 10000, config.camZ),
        u_worldSize: [size.halfW, size.halfH, size.halfD],
        u_gravity: config.gravity,
        u_texture: snowTexture,
        u_drift: () => windSim.drift,
      },
      count: particleCount,
      primitive: "points",
      blend: {
        enable: true,
        func: {
          srcRGB: "src alpha",
          dstRGB: "one",
          srcAlpha: "src alpha",
          dstAlpha: "one",
        },
      },
      depth: {
        enable: true,
      },
    });

    let lastTime = 0;
    regl.frame(({ time }) => {
      const dt = Math.min(time - lastTime, 0.05);
      lastTime = time;
      windSim.update(dt);
      drawSnow();
    });
  })();
</script>
