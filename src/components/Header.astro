---
import ThemeIcon from "@/components/ui/ThemeIcon.astro";
import { NAVIGATION, SITE_TITLE } from "@/constants";

const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};

const isExternal = (href: string) => href.startsWith("http");
---

<header class="flex h-18 min-h-18 items-center justify-between px-4 sm:px-6 lg:px-8">
  <a
    href="/"
    aria-label={SITE_TITLE}
    class="text-lg inline-flex border-s-4 border-zhu text-zhu px-4 transition-all duration-200"
  >
    {SITE_TITLE}
  </a>
  <div class="flex items-center gap-4">
    <nav class="flex items-center gap-4 text-sm tracking-[0.14em] sm:gap-6">
      {
        NAVIGATION.map(({ title, href }) => (
          <a
            href={href}
            target={isExternal(href) ? "_blank" : undefined}
            rel={isExternal(href) ? "noopener noreferrer" : undefined}
            class={`transition-colors ${
              isActive(href)
                ? "text-zhu underline underline-offset-8"
                : "text-text-muted hover:text-zhu-muted"
            }`}
          >
            {title}
          </a>
        ))
      }
    </nav>
    <ThemeIcon />
  </div>
</header>
